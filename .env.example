# =============================================================================
# Lead Audit Pro — Environment Configuration
# Copy to .env and fill in production values
# =============================================================================

# --- Application ---
APP_NAME=Lead Audit Pro
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-64-char-random-string-in-production
API_V1_PREFIX=/api/v1

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=leadaudit
POSTGRES_PASSWORD=leadaudit_secret
POSTGRES_DB=lead_audit_pro
DATABASE_URL=postgresql+asyncpg://leadaudit:leadaudit_secret@postgres:5432/lead_audit_pro
DATABASE_URL_SYNC=postgresql://leadaudit:leadaudit_secret@postgres:5432/lead_audit_pro

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Security ---
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=60
CSRF_SECRET_KEY=change-me-csrf-secret

# --- Celery ---
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4

# --- Nginx (Production) ---
NGINX_PORT=80
NGINX_SSL_PORT=443
